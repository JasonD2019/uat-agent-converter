{
  "name": "FastGPT 智能客服助手",
  "description": "企业级智能客服机器人，支持多轮对话和知识库检索",
  "avatar": "/avatars/customer-service.png",
  "version": "2.0",

  "workflow": {
    "nodes": [
      {
        "id": "node_start",
        "type": "start",
        "position": { "x": 100, "y": 200 },
        "data": {
          "title": "对话开始",
          "inputs": [
            { "key": "user_input", "type": "string", "label": "用户输入" }
          ]
        }
      },
      {
        "id": "node_knowledge_search",
        "type": "knowledgeSearch",
        "position": { "x": 300, "y": 200 },
        "data": {
          "title": "知识库检索",
          "datasetIds": ["kb-fastgpt-001", "kb-fastgpt-002"],
          "searchLimit": 5,
          "similarity": 0.65,
          "inputs": [{ "key": "query", "type": "string" }],
          "outputs": [{ "key": "searchResult", "type": "array" }]
        }
      },
      {
        "id": "node_llm",
        "type": "chatNode",
        "position": { "x": 500, "y": 200 },
        "data": {
          "title": "LLM 响应",
          "model": {
            "provider": "openai",
            "model": "gpt-4"
          },
          "systemPrompt": "你是一个专业的客服助手，请基于知识库检索结果回答用户问题。",
          "temperature": 0.7,
          "maxTokens": 2000
        }
      },
      {
        "id": "node_end",
        "type": "end",
        "position": { "x": 700, "y": 200 },
        "data": {
          "title": "对话结束",
          "outputs": [
            { "key": "response", "type": "string", "label": "客服回复" }
          ]
        }
      }
    ],
    "edges": [
      { "source": "node_start", "target": "node_knowledge_search" },
      { "source": "node_knowledge_search", "target": "node_llm" },
      { "source": "node_llm", "target": "node_end" }
    ]
  },

  "datasets": {
    "datasets": [
      {
        "id": "kb-fastgpt-001",
        "name": "产品FAQ知识库",
        "type": "external",
        "description": "产品常见问题和解答",
        "vectorModel": "text-embedding-3-small"
      },
      {
        "id": "kb-fastgpt-002",
        "name": "服务流程文档",
        "type": "external",
        "description": "客服标准处理流程",
        "vectorModel": "text-embedding-3-small"
      }
    ]
  },

  "modelConfig": {
    "model": "gpt-4",
    "temperature": 0.7,
    "maxTokens": 4096,
    "topP": 1,
    "frequencyPenalty": 0,
    "presencePenalty": 0
  },

  "agentIdentity": {
    "name": "智能客服",
    "role": "客服助手",
    "personality": ["耐心", "专业", "友好", "高效"]
  },

  "memory": {
    "longTermMemory": [
      "用户偏好快速解决问题",
      "常见问题类型: 产品咨询、投诉处理、售后支持"
    ],
    "sessionMemory": {
      "enabled": true,
      "maxMessages": 50
    }
  }
}