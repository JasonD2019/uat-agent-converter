{
  "name": "Flowise 数据分析助手",
  "description": "自动化数据分析流程，生成可视化报告",
  "version": "1.5",

  "nodes": [
    {
      "id": "node_start",
      "type": "startNode",
      "position": { "x": 100, "y": 100 },
      "data": {
        "title": "开始分析",
        "inputs": [
          { "key": "data_source", "type": "string", "label": "数据源" }
        ]
      }
    },
    {
      "id": "node_vector",
      "type": "vectorStoreRetriever",
      "position": { "x": 300, "y": 100 },
      "data": {
        "title": "知识库检索",
        "vectorStore": {
          "type": "pinecone",
          "indexName": "flowise-kb-index"
        },
        "embedding": {
          "model": "text-embedding-3-small"
        },
        "topK": 5
      }
    },
    {
      "id": "node_llm",
      "type": "chatModel",
      "position": { "x": 500, "y": 100 },
      "data": {
        "title": "LLM 分析",
        "model": "gpt-4",
        "provider": "openai",
        "temperature": 0.5,
        "systemPrompt": "基于检索的知识库内容进行数据分析"
      }
    },
    {
      "id": "node_qa",
      "type": "conversationalRetrievalQAChain",
      "position": { "x": 700, "y": 100 },
      "data": {
        "title": "问答生成",
        "inputs": {
          "llm": "node_llm",
          "retriever": "node_vector",
          "returnSourceDocuments": true
        }
      }
    },
    {
      "id": "node_output",
      "type": "outputNode",
      "position": { "x": 900, "y": 100 },
      "data": {
        "title": "输出结果",
        "outputs": [
          { "key": "analysis_report", "type": "string" },
          { "key": "source_documents", "type": "array" }
        ]
      }
    }
  ],

  "edges": [
    {
      "source": "node_start",
      "sourceHandle": "output",
      "target": "node_vector",
      "targetHandle": "query"
    },
    {
      "source": "node_vector",
      "sourceHandle": "retriever_output",
      "target": "node_qa",
      "targetHandle": "retriever_input"
    },
    {
      "source": "node_llm",
      "sourceHandle": "model_output",
      "target": "node_qa",
      "targetHandle": "llm_input"
    },
    {
      "source": "node_qa",
      "sourceHandle": "chain_output",
      "target": "node_output",
      "targetHandle": "input"
    }
  ],

  "knowledgeBase": {
    "refs": [
      {
        "id": "kb-flowise-001",
        "name": "数据分析方法论",
        "type": "md",
        "description": "统计分析方法和技术"
      },
      {
        "id": "kb-flowise-002",
        "name": "可视化模板库",
        "type": "json",
        "description": "图表配置模板"
      }
    ]
  },

  "agentConfig": {
    "identity": {
      "name": "DataAnalyst",
      "role": "数据分析师",
      "personality": ["精确", "逻辑", "可视化"]
    },
    "memory": {
      "longTerm": [
        "用户偏好 Python 数据分析",
        "常用 Pandas + Matplotlib"
      ],
      "sessionConfig": {
        "maxTurns": 20
      }
    }
  }
}